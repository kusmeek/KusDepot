<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup Label="Main">

        <Platforms>AnyCPU</Platforms>

        <OutputType>Library</OutputType>

        <AssemblyName>KusDepot.Builders</AssemblyName>

        <TargetFrameworks>net9.0;net10.0</TargetFrameworks>

    </PropertyGroup>

    <PropertyGroup Label="Analysis">

        <NoWarn>CS1591</NoWarn>

        <EnableTrimAnalyzer>False</EnableTrimAnalyzer>

    </PropertyGroup>

    <ItemGroup Label="Code">

        <Compile Include="DependencyInjection\DependencyInjection.cs" />
        <Compile Include="ToolBuilderFactory\ToolBuilderFactory.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\IToolBuilder.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\RegisteredCommand\RegisteredCommand.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\RegisteredHostedTool\RegisteredHostedTool.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\ToolBuilder.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\ToolBuilder.RegisterCommand.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\ToolBuilder.RegisterService.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\ToolBuilder.RegisterTool.cs" />
        <Compile Include="ToolBuilders\ToolBuilder\ToolBuilderContext\ToolBuilderContext.cs" />
        <Compile Include="ToolBuilders\ToolGenericHostBuilder\IToolGenericHostBuilder.cs" />
        <Compile Include="ToolBuilders\ToolGenericHostBuilder\ToolGenericHostBuilder.cs" />
        <Compile Include="ToolBuilders\ToolHostBuilder\IToolHostBuilder.cs" />
        <Compile Include="ToolBuilders\ToolHostBuilder\ToolHostBuilder.cs" />
        <Compile Include="ToolBuilders\ToolWebHostBuilder\IToolWebHostBuilder.cs" />
        <Compile Include="ToolBuilders\ToolWebHostBuilder\ToolWebHostBuilder.cs" />
        <Compile Include="Usings.cs" />

    </ItemGroup>

    <PropertyGroup Label="ConfigEx">

        <EnableDefaultItems>False</EnableDefaultItems>

        <EnableDefaultCompileItems>False</EnableDefaultCompileItems>

        <CopyLocalLockFileAssemblies>True</CopyLocalLockFileAssemblies>

    </PropertyGroup>

    <ItemGroup Label="Documentation">

        <Content Include="DependencyInjection\DependencyInjection.xml" Pack="false" />

        <Content Include="ToolBuilderFactory\ToolBuilderFactory.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolBuilder\IToolBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolBuilder\RegisteredCommand\RegisteredCommand.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolBuilder\RegisteredHostedTool\RegisteredHostedTool.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolBuilder\ToolBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolBuilder\ToolBuilderContext\ToolBuilderContext.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolGenericHostBuilder\IToolGenericHostBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolGenericHostBuilder\ToolGenericHostBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolHostBuilder\IToolHostBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolHostBuilder\ToolHostBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolWebHostBuilder\IToolWebHostBuilder.xml" Pack="false" />

        <Content Include="ToolBuilders\ToolWebHostBuilder\ToolWebHostBuilder.xml" Pack="false" />

    </ItemGroup>

    <ItemGroup Label="Packages or Projects">

        <ProjectReference Include="..\KusDepot.Objects\KusDepot.Objects.csproj" />

    </ItemGroup>

    <PropertyGroup Label="NuGet">

        <Title>KusDepot</Title>

        <IsPackable>True</IsPackable>

        <Authors>Mike Abrahams</Authors>

        <PackageTags>KusDepot</PackageTags>

        <RepositoryType>git</RepositoryType>

        <PackageIcon>gfxico.png</PackageIcon>

        <PackageId>KusDepot.Builders</PackageId>

        <PackageVersion>0.0.7-pre</PackageVersion>

        <PackageIconUrl>gfxico.png</PackageIconUrl>

        <Description>KusDepot Solution</Description>

        <ContentTargetFolders>\</ContentTargetFolders>

        <PackageReadmeFile>Readme.md</PackageReadmeFile>

        <IncludeContentInPack>True</IncludeContentInPack>

        <PackageLicenseExpression>MIT</PackageLicenseExpression>

        <Copyright>Copyright © 2026 Michael Abrahams</Copyright>

        <RepositoryUrl>https://github.com/kusmeek/KusDepot</RepositoryUrl>

        <PackageProjectUrl>https://github.com/kusmeek/KusDepot</PackageProjectUrl>

    </PropertyGroup>

    <ItemGroup Label="Readme">

        <None Include="..\Readme.md" Pack="true" PackagePath="\" />

        <None Include="..\KusDepot.Packages\images\gfxico.png" Pack="true" PackagePath="\" />

    </ItemGroup>

</Project>