<?xml version = "1.0" encoding = "utf-8" ?>

<ToolDescriptor>

    <record name = "ToolDescriptor">

        <main>

            <summary>Tool Descriptor.</summary>

            <remarks>An immutable record with tool identity and specification details.</remarks>

        </main>

        <property name = "ID" Cref = "Guid?"><summary>Tool identifier.</summary></property>

        <property name = "Type" Cref = "String?"><summary>Implementing Type's <see cref="Type.FullName"/>.</summary></property>

        <property name = "Specifications" Cref = "String?"><summary>Tool specifications.</summary></property>

        <property name = "ExtendedData" Cref = "List{String}?"><summary>Additional or contextual information.</summary></property>

        <method name = "Equals">

            <summary>Determine whether this instance references the same ToolDescriptor.</summary>

            <param name = "other" Cref = "ToolDescriptor?">Other ToolDescriptor.</param>

            <returns Cref = "Boolean">True if both references point to the same instance.</returns>

        </method>

        <method name = "Create">

            <summary>Create ToolDescriptor.</summary>

            <param name = "tool" Cref = "ITool">Tool.</param>

            <returns Cref = "ToolDescriptor">Tool Descriptor.</returns>

        </method>

        <method name = "TryParse">

            <summary>Try to Parse ToolDescriptor.</summary>

            <param name = "input" Cref = "String?">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <param name = "result" Cref = "ToolDescriptor">Output ToolDescriptor.</param>

            <returns Cref = "Boolean">True if input was parsed successfully.</returns>

        </method>

        <method name = "IParsable{ToolDescriptor}.Parse">

            <summary>Parse ToolDescriptor.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <returns Cref = "ToolDescriptor">Parsed ToolDescriptor.</returns>

        </method>

        <method name = "Parse">

            <summary>Parse ToolDescriptor.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <returns Cref = "ToolDescriptor?">Parsed ToolDescriptor.</returns>

        </method>

    </record>

</ToolDescriptor>
