<?xml version = "1.0" encoding = "utf-8" ?>
<ToolValueConfigurationConverter>

    <class name = "ToolValueConfigurationConverter">

        <main>

            <summary>Converter-owned ToolValue transport for IConfiguration.</summary>

        </main>

        <method name = "TryRead">

            <summary>Try read a custom-mode IConfiguration ToolValue.</summary>

            <param name = "value" Cref = "ToolValue?">Tool value.</param>

            <param name = "result" Cref = "Object?">Result.</param>

            <returns Cref = "Boolean">True on success.</returns>

        </method>

        <method name = "TryWrite">

            <summary>Try write IConfiguration as a custom-mode ToolValue.</summary>

            <param name = "value" Cref = "Object?">Value.</param>

            <param name = "result" Cref = "ToolValue?">Tool value.</param>

            <returns Cref = "Boolean">True on success.</returns>

        </method>

    </class>

</ToolValueConfigurationConverter>