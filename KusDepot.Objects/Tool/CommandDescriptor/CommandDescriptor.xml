<?xml version = "1.0" encoding = "utf-8" ?>

<CommandDescriptor>

    <record name = "CommandDescriptor">

        <main>

            <summary>Command Descriptor.</summary>

            <remarks>An immutable record with command specifications and tool registration details.</remarks>

        </main>

        <property name = "Type" Cref = "String?"><summary>Implementing Type's <see cref="Type.FullName"/>.</summary></property>

        <property name = "Specifications" Cref = "String?"><summary>Command specifications.</summary></property>

        <property name = "ExtendedData" Cref = "List{String}?"><summary>Additional or contextual information.</summary></property>

        <property name = "RegisteredHandles" Cref = "List{String}?"><summary>Handles registered to the Tool for this Command.</summary></property>

        <method name = "Equals">

            <summary>Determine whether this instance references the same CommandDescriptor.</summary>

            <param name = "other" Cref = "CommandDescriptor?">Other CommandDescriptor.</param>

            <returns Cref = "Boolean">True if both references point to the same instance.</returns>

        </method>

        <method name = "Create">

            <summary>Create CommandDescriptor.</summary>

            <param name = "command" Cref = "ICommand">Command.</param>

            <returns Cref = "CommandDescriptor">Command Descriptor.</returns>

        </method>

        <method name = "TryParse">

            <summary>Try to Parse CommandDescriptor.</summary>

            <param name = "input" Cref = "String?">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <param name = "result" Cref = "CommandDescriptor">Output CommandDescriptor.</param>

            <returns Cref = "Boolean">True if input was parsed successfully.</returns>

        </method>

        <method name = "IParsable{CommandDescriptor}.Parse">

            <summary>Parse CommandDescriptor.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <returns Cref = "CommandDescriptor">Parsed CommandDescriptor.</returns>

        </method>

        <method name = "Parse">

            <summary>Parse CommandDescriptor.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <returns Cref = "CommandDescriptor?">Parsed CommandDescriptor.</returns>

        </method>

    </record>

</CommandDescriptor>
