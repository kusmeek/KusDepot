            <returns Cref = "Boolean">True if access is granted.</returns>

        </method>

        <method name = "Activate_NoSync">

            <summary>Activate Tool without waiting for the LifeState lock.</summary>

            <param name = "cancel" Cref = "CancellationToken?">Cancellation Token.</param>

            <param name = "key" Cref = "AccessKey?">An AccessKey.</param>

            <returns Cref = "Task{Boolean}">True if Tool activated successfully.</returns>

        </method>

        <method name = "AddHostedService_NoSync">

            <summary>Add a hosted service without acquiring sync locks.</summary>

            <param name = "service" Cref = "IHostedService?">Hosted service instance.</param>

            <param name = "name" Cref = "String?">Optional hosted service registration name.</param>

            <param name = "permissions" Cref = "ImmutableArray{Int32}?">Optional protected-operation set granted to issued <see cref="KusDepot.Security.MyHostKey"/>.</param>

            <param name = "request" Cref = "HostRequest?">Optional host request used when the service is a Tool.</param>

            <param name = "start" Cref = "Boolean">True to start the hosted service after it is added.</param>

            <param name = "cancel" Cref = "CancellationToken">Cancellation Token.</param>

            <returns Cref = "Task{Boolean}">True if hosted service added successfully.</returns>

        </method>

