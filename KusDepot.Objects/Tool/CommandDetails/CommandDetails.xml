            <summary>Set ID.</summary>

            <param name = "id" Cref = "Guid?">ID.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetInputStream">

            <summary>Set InputStream argument.</summary>

            <param name = "stream" Cref = "Stream?">Input Stream.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetLogger">

            <summary>Set Logger.</summary>

            <param name = "logger" Cref = "ILogger?">Logger.</param>

