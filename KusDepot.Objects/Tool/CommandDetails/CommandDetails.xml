        </field>

        <field name = "handle" Cref = "String?"><summary>Command Handle.</summary></field>

        <field name = "id" Cref = "Guid?"><summary>Command ID.</summary></field>

        <field name = "workflow" Cref = "CommandWorkflow?"><summary>Command Workflow.</summary></field>

        <property name = "Arguments" Cref = "Dictionary{String,Object?}?"><summary>Command Arguments.</summary>
            <remarks>Names prefixed with exclamation mark (U+0021) are reserved for internal use.</remarks>
        </property>

        <property name = "MyArguments" Cref = "Dictionary{String,ToolValue?}?"><summary>ToolValue transport for command arguments.</summary></property>

        <property name = "Handle" Cref = "String?"><summary>Command Handle.</summary></property>

        <property name = "ID" Cref = "Guid?"><summary>Command ID.</summary></property>

        <property name = "Workflow" Cref = "CommandWorkflow?"><summary>Command Workflow.</summary></property>

