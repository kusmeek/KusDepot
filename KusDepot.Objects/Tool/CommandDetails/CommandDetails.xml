<?xml version = "1.0" encoding = "utf-8" ?>

<CommandDetails>

    <class name = "CommandDetails">

        <main>

            <summary>Details for execution of a Command.</summary>

        </main>

        <field name = "arguments" Cref = "Dictionary{String,Object?}?"><summary>Command Arguments.</summary>
