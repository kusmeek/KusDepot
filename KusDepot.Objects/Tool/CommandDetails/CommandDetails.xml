            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetToolCancel">

            <summary>Set the Tool cancellation token for asynchronous execution.</summary>

            <param name = "cancel" Cref = "CancellationToken">Cancellation token to use for Tool execution.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetWorkflow">

            <summary>Set Workflow.</summary>

            <param name = "workflow" Cref = "CommandWorkflow?">Workflow.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "IParsable{CommandDetails}.Parse">

            <summary>Parse CommandDetails.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <returns Cref = "CommandDetails">Parsed CommandDetails.</returns>

        </method>

        <method name = "Parse">

            <summary>Parse CommandDetails.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <returns Cref = "CommandDetails?">Parsed CommandDetails.</returns>

        </method>

        <method name = "TryParse">

            <summary>Try to Parse CommandDetails.</summary>

            <param name = "input" Cref = "String">Input to Parse.</param>

            <param name = "format" Cref = "IFormatProvider?">Format Provider.</param>

            <param name = "details" Cref = "CommandDetails">Output CommandDetails.</param>

            <returns Cref = "Boolean">True if input was parsed successfully.</returns>

        </method>

