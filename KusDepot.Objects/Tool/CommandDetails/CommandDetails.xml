            <param name = "arguments" Cref = "Dictionary{String,Object?}?">Arguments.</param>

            <param name = "handle" Cref = "String?">Handle.</param>

            <param name = "id" Cref = "Guid?">Identifier.</param>

            <param name = "workflow" Cref = "CommandWorkflow?">Workflow.</param>

            <returns Cref = "CommandDetails">New CommandDetails.</returns>

        </constructor>

        <method name = "Create">

            <summary>Construct CommandDetails.</summary>

            <returns Cref = "CommandDetails">New CommandDetails.</returns>

        </method>

        <method name = "GetKnownTypes">

            <summary>DataContractSerializer Known Types.</summary>

            <returns Cref = "IEnumerable{Type}">Known Types.</returns>

        </method>

        <method name = "OnDeserialized">

            <summary>Serialization Support.</summary>

            <param name = "context" Cref = "StreamingContext">Unused.</param>

        </method>

        <method name = "MakeReady">

            <summary>Checks for empty Handle and sets Arguments[AttachedToolID] to the caller's ID.</summary>

            <param name = "tool" Cref = "ITool">Executing Tool.</param>

            <returns Cref = "Boolean">True if CommandDetails is ready.</returns>

        </method>

        <method name = "GetAccessKey">

            <summary>Get AccessKey.</summary>

            <returns Cref = "AccessKey?">AccessKey.</returns>

        </method>

        <method name = "GetArgument">

            <summary>Get an Argument.</summary>

            <param name = "name" Cref = "String?">Argument Name.</param>

            <returns Cref = "Object?">Argument.</returns>

        </method>

        <method name = "GetArgumentType">

            <summary>Get an Argument.</summary>

            <typeparam name = "TResult">Type of Argument.</typeparam>

            <param name = "name" Cref = "String?">Argument Name.</param>

            <returns Cref = "TResult?">Argument.</returns>

        </method>

        <method name = "GetCancel">

            <summary>Get Cancel token.</summary>

            <returns Cref = "CancellationToken">Configured token or <see cref="CancellationToken.None"/>.</returns>

        </method>

        <method name = "GetLogger">

            <summary>Get Logger.</summary>

            <returns Cref = "ILogger?">Logger.</returns>

        </method>

        <method name = "GetTimeout">

            <summary>Get Timeout.</summary>

            <returns Cref = "TimeSpan?">Configured Timeout.</returns>

        </method>

        <method name = "GetToolCancel">

            <summary>Get the Tool cancellation token for asynchronous execution.</summary>

            <returns Cref = "CancellationToken">The configured Tool cancellation token, or <see cref="CancellationToken.None"/>.</returns>

        </method>

        <method name = "PreserveActivity">

            <summary>Set the PreserveActivity flag for this CommandDetails.</summary>

            <param name = "preserve" Cref = "Boolean">True to preserve activity; false to clean up activity after execution. Default is <see langword="false"/>.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetAccessKey">

            <summary>Set AccessKey.</summary>

            <param name = "key" Cref = "AccessKey?">Access Key.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetArgument">

            <summary>Set an Argument.</summary>

            <param name = "name" Cref = "String?">Argument Name.</param>

            <param name = "argument" Cref = "Object?">Argument Value.</param>

            <param name = "overwrite" Cref = "Boolean">True to overwrite argument.</param>

            <returns Cref = "CommandDetails">The same CommandDetails instance.</returns>

        </method>

        <method name = "SetAttachedToolID">

            <summary>Set the AttachedToolID argument.</summary>

            <param name = "id" Cref = "Guid">Attached Tool ID.</param>

