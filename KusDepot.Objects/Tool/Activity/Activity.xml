<?xml version = "1.0" encoding = "utf-8" ?>

<Activity>

    <class name = "Activity">

        <main>

            <summary>Task Tracking.</summary>

            <remarks>Activities manage the state of command execution.</remarks>

        </main>

        <field name = "freemode" Cref = "Boolean">

            <summary>True if the command runs in free mode and owns completion and record.</summary>

        </field>

        <field name = "cancel" Cref = "CancellationTokenSource?">

            <summary>Cancellation Token Source.</summary>

        </field>

        <field name = "details" Cref = "CommandDetails?">

            <summary>Command Details.</summary>

        </field>

        <field name = "handle" Cref = "String?">

            <summary>Execution Handle.</summary>

        </field>

        <field name = "id" Cref = "Guid?">

            <summary>Identifier.</summary>

        </field>

        <field name = "logger" Cref = "ILogger?">

            <summary>Logger.</summary>

        </field>

        <field name = "progress" Cref = "IProgress?">

            <summary>Progress monitor.</summary>

        </field>

        <field name = "record" Cref = "ActivityRecord?">

            <summary>Activity Record.</summary>

        </field>

        <field name = "started" Cref = "DateTimeOffset">

            <summary>When this Activity began.</summary>

        </field>

        <field name = "task" Cref = "Task{Object?}">

            <summary>Generated by ExecuteAsync.</summary>

        </field>

        <field name = "timeout" Cref = "TimeSpan">

            <summary>Timeout.</summary>

        </field>

        <property name = "Age" Cref = "TimeSpan">

            <summary>Activity Age.</summary>

        </property>

        <property name = "FreeMode" Cref = "Boolean">

            <summary>True if the command runs in free mode (tool does not await completion or set the ActivityRecord).</summary>

        </property>

        <property name = "Cancel" Cref = "CancellationTokenSource?">

            <summary>Cancellation Token Source.</summary>

        </property>

        <property name = "Details" Cref = "CommandDetails?">

            <summary>Activity Command Details.</summary>

        </property>

        <property name = "Handle" Cref = "String?">

            <summary>Execution Handle.</summary>

        </property>

        <property name = "ID" Cref = "Guid?">

            <summary>Identifier.</summary>

        </property>

        <property name = "Logger" Cref = "ILogger?">

            <summary>Logger.</summary>

        </property>

        <property name = "Progress" Cref = "IProgress{Object}?">

            <summary>Progress monitor.</summary>

        </property>

        <property name = "Record" Cref = "ActivityRecord?">

            <summary>Activity Record.</summary>

        </property>

        <property name = "Started" Cref = "DateTimeOffset?">

            <summary>When this Activity began.</summary>

        </property>

        <property name = "State" Cref = "ActivityState">

            <summary>Execution state of the Activity.</summary>

        </property>

        <property name = "Task" Cref = "Task{Object?}">

            <summary>Generated by ExecuteAsync.</summary>

        </property>

        <property name = "Timeout" Cref = "TimeSpan">

            <summary>Timeout.</summary>

        </property>

        <constructor name = "Constructor">

            <summary>Constructor.</summary>

        </constructor>

        <method name = "CreateActivity">

            <summary>Creates an Activity for a specific Command and execution mode.</summary>

            <param name ="details" Cref = "CommandDetails?">Details.</param>

            <param name ="command" Cref = "ICommand?">Command.</param>

            <param name ="asynchronous" Cref = "Boolean">True for asynchronous execution; false for synchronous.</param>

            <returns Cref = "Activity?">An Activity if the Command supports the requested mode; otherwise null.</returns>

        </method>

        <method name = "GetState">

            <summary>Compute the current ActivityState for this Activity.</summary>

            <returns Cref = "ActivityState">The current ActivityState.</returns>

        </method>

        <method name="IsTimedOut">

            <summary>Determines whether the current activity has timed out based on its configured timeout and cancellation tokens.</summary>

            <returns><see langword="true"/> if the activity has timed out; otherwise, <see langword="false"/>.</returns>

        </method>

        <method name = "LogWorkflowEvent">

            <summary>Log a workflow event.</summary>

            <param name = "action" Cref = "String?">Action name.</param>

            <param name = "data" Cref = "String?">Event data.</param>

            <returns Cref = "Boolean">True if appended.</returns>

        </method>

        <method name = "SetRecordByTool">

            <summary>Set the ActivityRecord when the tool is responsible for final disposition (FreeMode is false).</summary>

            <param name = "code" Cref = "ActivityRecordCode">Activity Record Code.</param>

            <param name = "message" Cref = "String?">Message.</param>

            <returns Cref = "Boolean">True if the record was set.</returns>

        </method>

        <method name = "SetRecordByCommand">

            <summary>Set the ActivityRecord when the command is responsible for final disposition (FreeMode is true).</summary>

            <param name = "code" Cref = "ActivityRecordCode">Activity Record Code.</param>

            <param name = "message" Cref = "String?">Message.</param>

            <returns Cref = "Boolean">True if the record was set.</returns>

        </method>

        <method name = "StartWorkflowAction">

            <summary>Log the start of a workflow action.</summary>

            <param name = "action" Cref = "String?">Action name.</param>

            <param name = "data" Cref = "String?">Event data.</param>

            <returns Cref = "Boolean">True if appended.</returns>

        </method>

        <method name = "StopWorkflowAction">

            <summary>Log the conclusion of a workflow action.</summary>

            <param name = "action" Cref = "String?">Action name.</param>

            <param name = "data" Cref = "String?">Event data.</param>

            <returns Cref = "Boolean">True if appended.</returns>

        </method>

        <method name = "CancelActivity">

            <summary>Request cancellation for this Activity via its CancellationTokenSource.</summary>

            <returns Cref = "Boolean">True if cancellation was requested; false if no token or already canceled.</returns>

        </method>

        <method name = "Dispose">

            <summary>Dispose of Activity.</summary>

        </method>

    </class>

</Activity>